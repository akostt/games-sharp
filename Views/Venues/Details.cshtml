@model GamesSharp.Models.Venue

@{
    ViewData["Title"] = "Детали места";
}

<div class="container mt-4">
    <h1><i class="bi bi-geo-alt"></i> Детали места проведения</h1>
    <hr />

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-9"><strong>@Html.DisplayFor(model => model.Name)</strong></dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Address)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Address)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Capacity)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Capacity)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Phone)</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.RentalCostPerHour)</dt>
                <dd class="col-sm-9">@(Model.RentalCostPerHour.HasValue ? Model.RentalCostPerHour.Value.ToString("0") + " ₽" : "-")</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>

                <dt class="col-sm-3">Координаты</dt>
                <dd class="col-sm-9">
                    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                    {
                        @Model.Latitude.Value.ToString("0.000000")<text>, </text>@Model.Longitude.Value.ToString("0.000000")
                    }
                    else
                    {
                        <span>-</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header bg-light">
            <h3 class="mb-0"><i class="bi bi-box-seam"></i> Инвентарь на площадке</h3>
        </div>
        <div class="card-body">
            @if (Model.VenueEquipments.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Оборудование</th>
                                <th>Тип</th>
                                <th>Количество</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.VenueEquipments.OrderBy(x => x.Equipment.Name))
                            {
                                <tr>
                                    <td>@item.Equipment.Name</td>
                                    <td>@(item.Equipment.EquipmentType?.Name ?? "-")</td>
                                    <td><span class="badge bg-primary">@item.Quantity</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Инвентарь для этой площадки не заполнен.</p>
            }
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-map"></i> Карта площадки</h3>
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <a href="https://yandex.ru/maps/?pt=@Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)&z=14&l=map"
                   target="_blank"
                   rel="noopener"
                   class="btn btn-sm btn-outline-primary">
                    Открыть в Яндекс Картах
                </a>
            }
        </div>
        <div class="card-body">
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <div id="venueDetailsMap" style="height: 340px; border-radius: 0.5rem;"></div>
            }
            else
            {
                <p class="text-muted mb-0">Карта недоступна: у точки не указаны координаты.</p>
            }
        </div>
    </div>

    <div class="mt-4">
        <h3><i class="bi bi-calendar-event"></i> Сессии в этом месте</h3>
        @if (Model.GameSessions.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Игра</th>
                        <th>Дата</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.GameSessions)
                    {
                        <tr>
                            <td>@(session.Game?.Name ?? "-")</td>
                            <td>@session.ScheduledDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(session.SessionStatus?.Name ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Нет запланированных сессий.</p>
        }
    </div>

    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Редактировать
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Назад к списку
        </a>
    </div>
</div>

@section Scripts {
    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const coords = [@Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), @Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)];
                const map = L.map('venueDetailsMap').setView(coords, 14);
                map.attributionControl.setPrefix(false);

                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '&copy; OpenStreetMap'
                }).addTo(map);

                L.marker(coords)
                    .addTo(map)
                    .bindPopup('@Model.Name.Replace("'", "\\'")')
                    .openPopup();
            });
        </script>
    }
}
