@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="p-4 p-md-5 rounded-4" style="background: linear-gradient(125deg, #fff8f8, #fff); border: 1px solid #ffd6d6;">
    <h1 class="text-danger mb-3"><i class="bi bi-exclamation-octagon"></i> Что-то пошло не так</h1>
    <p class="lead mb-4">Во время обработки запроса произошла ошибка. Попробуйте обновить страницу или вернуться на главную.</p>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house-door"></i> На главную
        </a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Назад
        </a>
    </div>
</div>

@if (Model.ShowRequestId)
{
    <p class="mt-4 mb-1"><strong>Идентификатор запроса:</strong> @Model.RequestId</p>
}

<h3 class="mt-4">Режим разработки</h3>
<p class="text-muted">
    В среде Development отображается подробная информация об ошибке. Для продакшена этот режим использовать не рекомендуется.
</p>
