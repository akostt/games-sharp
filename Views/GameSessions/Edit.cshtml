@model GamesSharp.Models.GameSession

@{
    ViewData["Title"] = "Редактировать сессию";
}

<div class="container mt-4">
    <h1><i class="bi bi-pencil"></i> Редактировать игровую сессию</h1>

<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
            }
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="GameId" class="control-label">Игра</label>
                <select asp-for="GameId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.GameId">
                    <option value="">-- Выберите игру --</option>
                </select>
                <span asp-validation-for="GameId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ScheduledDate" class="control-label"></label>
                <input asp-for="ScheduledDate" class="form-control" type="date" />
                <span asp-validation-for="ScheduledDate" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ActualStartTime" class="control-label"></label>
                        <input asp-for="ActualStartTime" class="form-control" type="time" asp-format="{0:HH:mm}" />
                        <span asp-validation-for="ActualStartTime" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ActualEndTime" class="control-label"></label>
                        <input asp-for="ActualEndTime" class="form-control" type="time" asp-format="{0:HH:mm}" />
                        <span asp-validation-for="ActualEndTime" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group mb-3">
                <label asp-for="VenueId" class="control-label"></label>
                <select asp-for="VenueId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.VenueId">
                    <option value="">-- Выберите место --</option>
                </select>
                <span asp-validation-for="VenueId" class="text-danger"></span>
            </div>
            <div class="card mb-3">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box-seam"></i> Инвентарь для бронирования</span>
                    <small class="text-muted">Сравнение "требуется" и "на площадке"</small>
                </div>
                <div class="card-body">
                    <div id="equipmentAvailabilityPlaceholder" class="text-muted">Выберите игру и место проведения.</div>
                    <div id="equipmentAvailabilityContainer" class="table-responsive d-none">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Оборудование</th>
                                    <th>Требуется</th>
                                    <th>Доступно</th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody id="equipmentAvailabilityBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="form-group mb-3">
                <label asp-for="SessionStatusId" class="control-label">Статус</label>
                <select asp-for="SessionStatusId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.SessionStatusId">
                    <option value="">-- Выберите статус --</option>
                </select>
                <span asp-validation-for="SessionStatusId" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Organizer" class="control-label"></label>
                        <input asp-for="Organizer" class="form-control" />
                        <span asp-validation-for="Organizer" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MaxParticipants" class="control-label"></label>
                        <input asp-for="MaxParticipants" class="form-control" type="number" min="1" max="100" />
                        <span asp-validation-for="MaxParticipants" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Игроки</label>
                <select name="selectedPlayers" class="form-select" multiple size="5" asp-items="(IEnumerable<SelectListItem>)ViewBag.Players">
                </select>
                <small class="form-text text-muted">Удерживайте Ctrl (или Cmd на Mac) для выбора нескольких игроков</small>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Notes" class="control-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3 mb-4">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-action="Results" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bi bi-trophy"></i> Результаты</a>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Назад к списку</a>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const gameSelect = document.getElementById('GameId');
            const venueSelect = document.getElementById('VenueId');
            const placeholder = document.getElementById('equipmentAvailabilityPlaceholder');
            const container = document.getElementById('equipmentAvailabilityContainer');
            const body = document.getElementById('equipmentAvailabilityBody');

            async function refreshAvailability() {
                const gameId = parseInt(gameSelect.value, 10);
                const venueId = parseInt(venueSelect.value, 10);

                if (!Number.isFinite(gameId) || !Number.isFinite(venueId)) {
                    placeholder.textContent = 'Выберите игру и место проведения.';
                    placeholder.classList.remove('d-none');
                    container.classList.add('d-none');
                    body.innerHTML = '';
                    return;
                }

                try {
                    const response = await fetch(`/GameSessions/GetEquipmentAvailability?gameId=${gameId}&venueId=${venueId}`);
                    if (!response.ok) {
                        throw new Error('Не удалось получить данные по оборудованию.');
                    }

                    const items = await response.json();
                    body.innerHTML = '';

                    if (!items.length) {
                        placeholder.textContent = 'Для выбранной игры не задано обязательное оборудование.';
                        placeholder.classList.remove('d-none');
                        container.classList.add('d-none');
                        return;
                    }

                    items.forEach(item => {
                        const statusBadge = item.isEnough
                            ? '<span class="badge bg-success">Хватает</span>'
                            : '<span class="badge bg-danger">Недостаточно</span>';

                        const row = `<tr>
                            <td>${item.equipmentName}</td>
                            <td><span class="badge bg-primary">${item.requiredQuantity}</span></td>
                            <td><span class="badge bg-info">${item.availableQuantity}</span></td>
                            <td>${statusBadge}</td>
                        </tr>`;

                        body.insertAdjacentHTML('beforeend', row);
                    });

                    placeholder.classList.add('d-none');
                    container.classList.remove('d-none');
                } catch (error) {
                    placeholder.textContent = error.message;
                    placeholder.classList.remove('d-none');
                    container.classList.add('d-none');
                    body.innerHTML = '';
                }
            }

            gameSelect.addEventListener('change', refreshAvailability);
            venueSelect.addEventListener('change', refreshAvailability);
            refreshAvailability();
        });
    </script>
}
