@model GamesSharp.Models.GameSession

@{
    ViewData["Title"] = "Детали сессии";
}

<div class="container mt-4">
    <h1><i class="bi bi-calendar-event"></i> Детали игровой сессии</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Игра</dt>
        <dd class="col-sm-9">@(Model.Game?.Name ?? "-")</dd>
        
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ScheduledDate)</dt>
        <dd class="col-sm-9">@Model.ScheduledDate.ToString("dd.MM.yyyy")</dd>
        
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ActualStartTime)</dt>
        <dd class="col-sm-9">@(Model.ActualStartTime.HasValue ? Model.ActualStartTime.Value.ToString("dd.MM.yyyy HH:mm") : "-")</dd>
        
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ActualEndTime)</dt>
        <dd class="col-sm-9">@(Model.ActualEndTime.HasValue ? Model.ActualEndTime.Value.ToString("dd.MM.yyyy HH:mm") : "-")</dd>
        
        <dt class="col-sm-3">Место проведения</dt>
        <dd class="col-sm-9">@(Model.Venue?.Name ?? "-")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Organizer)</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Organizer) ? "-" : Model.Organizer)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.MaxParticipants)</dt>
        <dd class="col-sm-9">@(Model.MaxParticipants.HasValue ? Model.MaxParticipants.Value.ToString() : "-")</dd>
        
        <dt class="col-sm-3">Статус</dt>
        <dd class="col-sm-9">
            @if (Model.SessionStatus?.Code == "completed")
            {
                <span class="badge bg-success">@(Model.SessionStatus?.Name ?? "-")</span>
            }
            else if (Model.SessionStatus?.Code == "in_progress")
            {
                <span class="badge bg-primary">@(Model.SessionStatus?.Name ?? "-")</span>
            }
            else if (Model.SessionStatus?.Code == "cancelled")
            {
                <span class="badge bg-danger">@(Model.SessionStatus?.Name ?? "-")</span>
            }
            else
            {
                <span class="badge bg-secondary">@(Model.SessionStatus?.Name ?? "-")</span>
            }
        </dd>
        
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Notes)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Notes)</dd>
    </dl>
</div>

<div class="mt-4">
    <h3><i class="bi bi-people"></i> Игроки</h3>
    @if (Model.SessionPlayers.Any())
    {
        var orderedPlayers = Model.SessionPlayers
            .OrderByDescending(sp => sp.IsWinner)
            .ThenByDescending(sp => sp.Score ?? int.MinValue)
            .ThenBy(sp => sp.Player?.Name)
            .ToList();

        var place = 0;
        var rank = 0;
        int? previousScore = null;

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Место</th>
                    <th>Имя игрока</th>
                    <th>Очки</th>
                    <th>Победитель</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sp in orderedPlayers)
                {
                    if (sp.Score.HasValue)
                    {
                        rank++;
                        if (previousScore != sp.Score)
                        {
                            place = rank;
                            previousScore = sp.Score;
                        }
                    }
                    else
                    {
                        place = 0;
                    }

                    <tr>
                        <td>@(place > 0 ? place : "-")</td>
                        <td>@(sp.Player?.Name ?? "-")</td>
                        <td>@(sp.Score.HasValue ? sp.Score.Value.ToString() : "-")</td>
                        <td>@(sp.IsWinner ? "✓" : "")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Нет игроков в этой сессии.</p>
    }
</div>

<div class="mt-4">
    <a asp-action="Results" asp-route-id="@Model.Id" class="btn btn-primary">
        <i class="bi bi-trophy"></i> Внести результаты
    </a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
        <i class="bi bi-pencil"></i> Редактировать
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад к списку
    </a>
</div>
</div>
