@model GamesSharp.Models.PaginatedList<GamesSharp.Models.Game>

@{
    ViewData["Title"] = "Настольные игры";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4">
            <i class="bi bi-dice-5"></i> Настольные игры
        </h1>
        <div class="d-flex gap-2">
            <a asp-action="ExportToExcel" class="btn btn-outline-success btn-lg">
                <i class="bi bi-file-earmark-excel"></i> Экспорт в Excel
            </a>
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle"></i> Добавить игру
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Название</th>
                        <th>Категории</th>
                        <th>Издатель</th>
                        <th>Мин. игроков</th>
                        <th>Макс. игроков</th>
                        <th>Длительность</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
            @if (Model.Items.Any())
            {
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <strong>@Html.DisplayFor(modelItem => item.Name)</strong>
                            @if (item.YearPublished.HasValue)
                            {
                                <br/><small class="text-muted">(@item.YearPublished)</small>
                            }
                        </td>
                        <td>
                            @if (item.GameCategoryAssignments.Any())
                            {
                                foreach (var category in item.GameCategoryAssignments.Select(gca => gca.GameCategory).Where(gc => gc != null))
                                {
                                    <span class="badge bg-info me-1">@category!.Name</span>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>@(item.Publisher?.Name ?? "-")</td>
                        <td>@Html.DisplayFor(modelItem => item.MinPlayers)</td>
                        <td>@Html.DisplayFor(modelItem => item.MaxPlayers)</td>
                        <td>@Html.DisplayFor(modelItem => item.AverageDuration) мин</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Подробности">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4">
                        <i class="bi bi-info-circle"></i> Игры пока не добавлены.
                        <a asp-action="Create" class="ms-1">Создать первую игру</a>
                    </td>
                </tr>
            }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@Model.PreviousPageNumber">
                        <i class="bi bi-chevron-left"></i> Предыдущая
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link"><i class="bi bi-chevron-left"></i> Предыдущая</span>
                </li>
            }

            <li class="page-item active">
                <span class="page-link">
                    Страница @Model.PageNumber из @Model.TotalPages
                </span>
            </li>

            @if (Model.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@Model.NextPageNumber">
                        Следующая <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">Следующая <i class="bi bi-chevron-right"></i></span>
                </li>
            }
        </ul>
    </nav>

    <div class="text-center mt-3 text-muted">
        <small>Всего игр: <strong>@Model.TotalCount</strong> | Показано: <strong>@Model.Items.Count</strong></small>
    </div>
</div>
